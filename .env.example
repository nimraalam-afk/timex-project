# Example environment variables for the Timex Scout backend.
# All are OPTIONAL: the demo runs end to end with none of them set
# (the recommender and evaluator use deterministic fallbacks).

# Enables the LLM path for the recommender and evaluator when set.
# OPENAI_API_KEY=sk-...

# Overrides the OpenAI model used when a key is set (default: gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

OPENAI_API_KEY=your_openai_key_here

EBAY_CLIENT_ID=your_ebay_client_id_here
EBAY_CLIENT_SECRET=your_ebay_client_secret_here
EBAY_DEV_ID=your_ebay_dev_id_here
EBAY_MARKETPLACE_ID=
LISTING_SOURCE=
EBAY_REDIRECT_URI=
EBAY_ENV=

ETSY_SHARED_SECRET=
