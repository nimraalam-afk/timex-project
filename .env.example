# Example environment variables for the Timex Scout backend.
# All are OPTIONAL: the demo runs end to end with none of them set
# (the recommender and evaluator use deterministic fallbacks).
#
# Every line below is commented out on purpose. Copy this file to `.env` and
# uncomment only what you need. Leaving placeholders active would make the app
# think OpenAI is enabled, so keep them commented until you add real values.

# Enables the LLM path for the recommender and evaluator when set to a real key.
# OPENAI_API_KEY=sk-your-real-key-here

# Overrides the OpenAI model used when a key is set (default: gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

# --- Live marketplace provider (opt-in; defaults to seed) -------------------
# Select the listing source. Leave as "seed" (default) for the reliable demo;
# set to "ebay" to opt in to the live eBay Browse API provider. eBay is only
# used when LISTING_SOURCE=ebay AND real credentials below are present; any
# failure falls back to seed data automatically.
# LISTING_SOURCE=seed

# eBay OAuth client credentials (App ID / Cert ID). Placeholders are treated as
# disabled, so keep them commented until you add real values.
# EBAY_CLIENT_ID=your_ebay_client_id_here
# EBAY_CLIENT_SECRET=your_ebay_client_secret_here

# "production" (default) or "sandbox".
# EBAY_ENV=production

# Marketplace and candidate pool size (limit is clamped to 1-50).
# EBAY_MARKETPLACE_ID=EBAY_CA
# EBAY_RESULT_LIMIT=30
